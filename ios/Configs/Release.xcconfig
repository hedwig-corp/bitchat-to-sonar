MARKETING_VERSION = 1.6.0
CURRENT_PROJECT_VERSION = 1

IPHONEOS_DEPLOYMENT_TARGET = 16.0
MACOSX_DEPLOYMENT_TARGET = 15.0
SWIFT_VERSION = 5.0

DEVELOPMENT_TEAM = L3N5LHJD5Y
CODE_SIGN_STYLE = Automatic

PRODUCT_BUNDLE_IDENTIFIER = sh.hedwig.sonar

APP_GROUP_ID = group.sh.hedwig.sonar

// Default (empty) BREEZ_API_KEY: the wallet stays inactive unless a real key is
// provided. Secrets live ONLY in the gitignored Local.xcconfig, included below
// so local Release builds / archives (TestFlight) pick up the key + signing team
// without ever committing them. CI should inject BREEZ_API_KEY the same way.
BREEZ_API_KEY =
#include? "Local.xcconfig"
