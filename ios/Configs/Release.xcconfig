MARKETING_VERSION = 1.6.0
CURRENT_PROJECT_VERSION = 1

IPHONEOS_DEPLOYMENT_TARGET = 16.0
MACOSX_DEPLOYMENT_TARGET = 15.0
SWIFT_VERSION = 5.0

// The native Rust dependencies (arti.xcframework, libarti_bitchat.a,
// libsonar_ffi.a) ship arm64-only slices for macOS. Archives force
// ONLY_ACTIVE_ARCH=NO and would otherwise try to build the x86_64 slice,
// failing to link the Arti FFI symbols. macOS is Apple-silicon only here,
// so exclude x86_64 for the macOS SDK (iOS builds are unaffected).
EXCLUDED_ARCHS[sdk=macosx*] = x86_64

DEVELOPMENT_TEAM = L3N5LHJD5Y
CODE_SIGN_STYLE = Automatic

PRODUCT_BUNDLE_IDENTIFIER = sh.hedwig.sonar

APP_GROUP_ID = group.sh.hedwig.sonar

// Default (empty) secrets: inactive unless a real value is provided.
// Secrets live ONLY in the gitignored Local.xcconfig, included below
// so local Release builds / archives (TestFlight) pick up the key + signing team
// without ever committing them. CI should inject these the same way.
BREEZ_API_KEY =
TRANSPONDER_NPUB =
NDS_URL =
#include? "Local.xcconfig"
