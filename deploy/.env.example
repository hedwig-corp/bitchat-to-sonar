# Sonar Notification Stack — Environment Configuration
#
# Copy this file to .env and fill in the values.
# See deploy/README.md for full setup instructions.
#
# IMPORTANT: Never commit the .env file or the secrets/ directory.

# ---------------------------------------------------------------------------
# Transponder (Marmot chat/call push server)
# ---------------------------------------------------------------------------

# Log level for the transponder Rust binary.
# Options: trace, debug, info, warn, error
RUST_LOG=info

# ---------------------------------------------------------------------------
# Breez NDS (wallet wakeup server)
# ---------------------------------------------------------------------------

# Public-facing URL where the NDS is reachable by the Breez swap service.
# Clients register webhooks using this base URL:
#   https://<host>/api/v1/notify?platform=<ios|android>&token=<PUSH_TOKEN>
NOTIFY_EXTERNAL_URL=https://notify.sonar.example.com

# Number of worker goroutines processing the notification queue.
NOTIFY_WORKERS_NUM=4

# Local address the NDS container binds to (host:port mapping).
# Default: 127.0.0.1:8080 (localhost only). Use 0.0.0.0:8080 to expose.
NDS_LISTEN_ADDRESS=127.0.0.1:8080
